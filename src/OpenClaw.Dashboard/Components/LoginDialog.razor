@implements IDisposable
@inject LocalizationService L
@inject AuthService Auth

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@L["auth.login"]</MudText>
    </TitleContent>
    <DialogContent>
        <MudTabs @bind-ActivePanelIndex="_activeTab"
                 Elevation="0"
                 Rounded="true"
                 ApplyEffectsToContainer="true">
            <MudTabPanel Text="@L["auth.loginWithCredentials"]">
                <MudTextField @bind-Value="_username"
                              Label="@L["auth.username"]"
                              Variant="Variant.Outlined"
                              Class="mt-4" />
                <MudTextField @bind-Value="_password"
                              Label="@L["auth.password"]"
                              Variant="Variant.Outlined"
                              InputType="InputType.Password"
                              Class="mt-2" />
            </MudTabPanel>

            <MudTabPanel Text="@L["auth.loginWithToken"]">
                <MudTextField @bind-Value="_token"
                              Label="@L["auth.token"]"
                              Variant="Variant.Outlined"
                              InputType="InputType.Password"
                              Class="mt-4" />
            </MudTabPanel>

            <MudTabPanel Text="@L["auth.loginWithBootstrap"]">
                <MudTextField @bind-Value="_bootstrapToken"
                              Label="@L["auth.bootstrapToken"]"
                              Variant="Variant.Outlined"
                              InputType="InputType.Password"
                              Class="mt-4" />
            </MudTabPanel>
        </MudTabs>

        @if (!string.IsNullOrEmpty(_error))
        {
            <MudAlert Severity="Severity.Error" Class="mt-4">@_error</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@L["common.cancel"]</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="HandleLogin"
                   Disabled="_loading">
            @if (_loading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            @L["auth.login"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    private int _activeTab;
    private string _username = string.Empty;
    private string _password = string.Empty;
    private string _token = string.Empty;
    private string _bootstrapToken = string.Empty;
    private string? _error;
    private bool _loading;

    protected override void OnInitialized()
    {
        L.OnLanguageChanged += HandleStateChanged;
    }

    private async Task HandleLogin()
    {
        _loading = true;
        _error = null;

        var success = _activeTab switch
        {
            0 => await Auth.LoginWithCredentials(_username, _password),
            1 => await Auth.LoginWithToken(_token),
            2 => await Auth.LoginWithBootstrap(_bootstrapToken),
            _ => false
        };

        _loading = false;

        if (success)
        {
            MudDialog.Close(DialogResult.Ok(true));
        }
        else
        {
            _error = L["auth.loginFailed"];
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private void HandleStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        L.OnLanguageChanged -= HandleStateChanged;
    }
}
