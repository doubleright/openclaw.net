    /// <summary>
    /// Maps Gateway's <c>SessionSummary</c> array (camelCase: <c>id</c>, <c>channelId</c>,
    /// <c>senderId</c>, <c>lastActiveAt</c>) into Dashboard's <see cref="SessionInfo"/>
    /// records, deduping by id so an "active" entry is not double-listed by the persisted page.
    /// </summary>
    private static void AppendSessionSummaries(
        System.Text.Json.JsonElement array,
        List<SessionInfo> dest,
        HashSet<string> seen)
    {
        foreach (var el in array.EnumerateArray())
        {
            if (el.ValueKind != System.Text.Json.JsonValueKind.Object) continue;

            var id = ReadJsonString(el, "id") ?? ReadJsonString(el, "sessionId");
            if (string.IsNullOrEmpty(id) || !seen.Add(id)) continue;

            var channelId = ReadJsonString(el, "channelId");
            var senderId = ReadJsonString(el, "senderId");
            var lastActive = ReadJsonDateTime(el, "lastActiveAt") ?? ReadJsonDateTime(el, "lastActive");
            var totalInputTokens = ReadJsonInt64(el, "totalInputTokens");
            var totalOutputTokens = ReadJsonInt64(el, "totalOutputTokens");
            var totalCacheReadTokens = ReadJsonInt64(el, "totalCacheReadTokens");
            var totalCacheWriteTokens = ReadJsonInt64(el, "totalCacheWriteTokens");

            dest.Add(new SessionInfo(
                id,
                channelId,
                senderId,
                lastActive,
                totalInputTokens,
                totalOutputTokens,
                totalCacheReadTokens,
                totalCacheWriteTokens,
                null));
        }
    }

    private static string? ReadJsonString(System.Text.Json.JsonElement el, string name)
        => el.TryGetProperty(name, out var v) && v.ValueKind == System.Text.Json.JsonValueKind.String
            ? v.GetString()
            : null;

    private static DateTime? ReadJsonDateTime(System.Text.Json.JsonElement el, string name)
    {
        if (!el.TryGetProperty(name, out var v) || v.ValueKind != System.Text.Json.JsonValueKind.String)
            return null;
        return v.TryGetDateTime(out var dt) ? dt : null;
    }

    private static long ReadJsonInt64(System.Text.Json.JsonElement el, string name)
    {
        if (!el.TryGetProperty(name, out var v))
            return 0;

        if (v.ValueKind == System.Text.Json.JsonValueKind.Number && v.TryGetInt64(out var direct))
            return direct;

        if (v.ValueKind == System.Text.Json.JsonValueKind.String
            && long.TryParse(v.GetString(), out var parsed))
            return parsed;

        return 0;
    }

    /// <summary>
    /// Maps Gateway's <c>AdminSessionDetailResponse</c> envelope (containing a nested
    /// <c>Session</c> with <c>history</c> of <c>ChatTurn</c>, plus <c>isActive</c> /
    /// <c>branchCount</c> / <c>metadata</c>) into the Dashboard <see cref="SessionDetail"/> shape.
    /// </summary>
    private static SessionDetail BuildSessionDetailFromAdmin(
        SessionInfo fallback,
        System.Text.Json.JsonElement root,
        System.Text.Json.JsonElement sessionEl)
    {
        var id = ReadJsonString(sessionEl, "id") ?? fallback.SessionId;
        var channelId = ReadJsonString(sessionEl, "channelId") ?? fallback.ChannelId;
        var senderId = ReadJsonString(sessionEl, "senderId") ?? fallback.SenderId;
        var lastActive = ReadJsonDateTime(sessionEl, "lastActiveAt") ?? fallback.LastActive;
        var totalInputTokens = ReadJsonInt64(sessionEl, "totalInputTokens");
        var totalOutputTokens = ReadJsonInt64(sessionEl, "totalOutputTokens");
        var totalCacheReadTokens = ReadJsonInt64(sessionEl, "totalCacheReadTokens");
        var totalCacheWriteTokens = ReadJsonInt64(sessionEl, "totalCacheWriteTokens");

        var messages = new List<SessionMessage>();
        if (sessionEl.TryGetProperty("history", out var history)
            && history.ValueKind == System.Text.Json.JsonValueKind.Array)
        {
            foreach (var turn in history.EnumerateArray())
            {
                if (turn.ValueKind != System.Text.Json.JsonValueKind.Object) continue;
                var role = ReadJsonString(turn, "role") ?? "unknown";
                var content = ReadJsonString(turn, "content");
                var timestamp = ReadJsonDateTime(turn, "timestamp");
                messages.Add(new SessionMessage(role, content, timestamp));
            }
        }

        // Fold isActive / branchCount / metadata snapshot into the Dictionary so the
        // existing metadata renderer keeps working without introducing a new model.
        var metadata = new Dictionary<string, object>(StringComparer.Ordinal);
        if (root.TryGetProperty("isActive", out var isActive)
            && isActive.ValueKind is System.Text.Json.JsonValueKind.True or System.Text.Json.JsonValueKind.False)
        {
            metadata["isActive"] = isActive.GetBoolean();
        }
        if (root.TryGetProperty("branchCount", out var branchCount)
            && branchCount.ValueKind == System.Text.Json.JsonValueKind.Number
            && branchCount.TryGetInt32(out var bc))
        {
            metadata["branchCount"] = bc;
        }
        if (root.TryGetProperty("metadata", out var metaEl)
            && metaEl.ValueKind == System.Text.Json.JsonValueKind.Object)
        {
            // Flatten the envelope metadata object so top-level keys like "branches"
            // are directly accessible to FormatMetadata / ExtractBranches.
            // Later keys overwrite earlier entries to honor the envelope payload.
            foreach (var property in metaEl.EnumerateObject())
            {
                metadata[property.Name] = property.Value.Clone();
            }
        }

        return new SessionDetail(
            id,
            channelId,
            senderId,
            lastActive,
            totalInputTokens,
            totalOutputTokens,
            totalCacheReadTokens,
            totalCacheWriteTokens,
            metadata.Count == 0 ? null : metadata, messages);
    }

    private async Task LoadSessionTimeline(string sessionId)
    {
        if (!string.Equals(_currentDetailSessionId, sessionId, StringComparison.Ordinal))
            return;

        _providerTurns = [];
        _timelineLoadError = null;

        try
        {
            using var resp = await Api.GetRawAsync($"/admin/sessions/{sessionId}/timeline?limit=50");
            if (!resp.IsSuccessStatusCode)
            {
                if (string.Equals(_currentDetailSessionId, sessionId, StringComparison.Ordinal))
                {
                    _timelineLoadError = $"{L["common.error"]}: {resp.StatusCode}";
                    _providerTurns = [];
                    StateHasChanged();
                }
                return;
            }

            using var stream = await resp.Content.ReadAsStreamAsync();
            using var doc = await System.Text.Json.JsonDocument.ParseAsync(stream);
            var root = doc.RootElement;

            if (root.TryGetProperty("sessionId", out var timelineSessionId)
                && timelineSessionId.ValueKind == System.Text.Json.JsonValueKind.String
                && !string.Equals(timelineSessionId.GetString(), sessionId, StringComparison.Ordinal))
            {
                return;
            }

            if (root.ValueKind != System.Text.Json.JsonValueKind.Object
                || !root.TryGetProperty("providerTurns", out var providerTurns)
                || providerTurns.ValueKind != System.Text.Json.JsonValueKind.Array)
            {
                if (string.Equals(_currentDetailSessionId, sessionId, StringComparison.Ordinal))
                {
                    _providerTurns = [];
                    StateHasChanged();
                }
                return;
            }

            var parsed = new List<ProviderTurnView>(providerTurns.GetArrayLength());
            foreach (var turn in providerTurns.EnumerateArray())
            {
                if (turn.ValueKind != System.Text.Json.JsonValueKind.Object)
                    continue;

                parsed.Add(new ProviderTurnView(
                    ReadJsonDateTimeOffset(turn, "timestampUtc") ?? DateTimeOffset.UtcNow,
                    ReadJsonString(turn, "providerId") ?? "unknown",
                    ReadJsonString(turn, "modelId") ?? "default",
                    ReadJsonInt64(turn, "inputTokens"),
                    ReadJsonInt64(turn, "outputTokens"),
                    ReadJsonInt64(turn, "cacheReadTokens"),
                    ReadJsonInt64(turn, "cacheWriteTokens")));
            }

            if (string.Equals(_currentDetailSessionId, sessionId, StringComparison.Ordinal))
            {
                _providerTurns = parsed;
                _timelineLoadError = null;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            if (string.Equals(_currentDetailSessionId, sessionId, StringComparison.Ordinal))
            {
                _timelineLoadError = ex.Message;
                _providerTurns = [];
                StateHasChanged();
            }
        }
    }

    private static DateTimeOffset? ReadJsonDateTimeOffset(System.Text.Json.JsonElement el, string name)
    {
        if (!el.TryGetProperty(name, out var v) || v.ValueKind != System.Text.Json.JsonValueKind.String)
            return null;
        return v.TryGetDateTimeOffset(out var dto) ? dto : null;
    }

    private static string FormatTokenCount(long value) => value.ToString("N0");

    private sealed record ProviderTurnView(
        DateTimeOffset TimestampUtc,
        string ProviderId,
        string ModelId,
        long InputTokens,
        long OutputTokens,
        long CacheReadTokens,
        long CacheWriteTokens);
}
