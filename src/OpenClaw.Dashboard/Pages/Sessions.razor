</style>

@code {
    private List<SessionInfo>? _sessions;
    private SessionDetail? _selectedDetail;
    private string _search = string.Empty;
    private string _channelFilter = string.Empty;
    private string _senderFilter = string.Empty;
    private int _page = 1;
    private const int PageSize = 20;
    private bool _hasMore;
    private bool _loading = true;
    private bool _loadingDetail;

    private bool _metadataDialog;
    private bool _diffDialog;
    private string _metadataJson = string.Empty;
    private string _diffContent = string.Empty;

    private readonly DialogOptions _dialogOptions = new()
    {
        MaxWidth = MaxWidth.Medium,
        FullWidth = true,
        CloseOnEscapeKey = true
    };

    protected override async Task OnInitializedAsync()
    {
        L.OnLanguageChanged += HandleLanguageChanged;
        await LoadSessions();
    }

    private void HandleLanguageChanged() => InvokeAsync(StateHasChanged);

    private async Task LoadSessions()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            var url = $"/admin/sessions?page={_page}&pageSize={PageSize}"
                + (string.IsNullOrEmpty(_search) ? string.Empty : $"&search={Uri.EscapeDataString(_search)}")
                + (string.IsNullOrEmpty(_channelFilter) ? string.Empty : $"&channelId={Uri.EscapeDataString(_channelFilter)}")
                + (string.IsNullOrEmpty(_senderFilter) ? string.Empty : $"&senderId={Uri.EscapeDataString(_senderFilter)}");

            using var resp = await Api.GetRawAsync(url);
            if (!resp.IsSuccessStatusCode)
            {
                _sessions = new List<SessionInfo>();
                _hasMore = false;
                return;
            }

            using var stream = await resp.Content.ReadAsStreamAsync();
            using var doc = await System.Text.Json.JsonDocument.ParseAsync(stream);
            var root = doc.RootElement;

            System.Text.Json.JsonElement arr = root;
            if (root.ValueKind == System.Text.Json.JsonValueKind.Object)
            {
                if (root.TryGetProperty("sessions", out var s) &&
                    s.ValueKind == System.Text.Json.JsonValueKind.Array)
                {
                    arr = s;
                }
                else if (root.TryGetProperty("items", out var i) &&
                    i.ValueKind == System.Text.Json.JsonValueKind.Array)
                {
                    arr = i;
                }

                if (root.TryGetProperty("hasMore", out var hm) &&
                    hm.ValueKind is System.Text.Json.JsonValueKind.True or System.Text.Json.JsonValueKind.False)
                {
                    _hasMore = hm.GetBoolean();
                }
                else
                {
                    _hasMore = false;
                }
            }

            if (arr.ValueKind == System.Text.Json.JsonValueKind.Array)
            {
                _sessions = System.Text.Json.JsonSerializer.Deserialize<List<SessionInfo>>(arr.GetRawText(), Api.JsonOptions)
                            ?? new List<SessionInfo>();
                if (root.ValueKind != System.Text.Json.JsonValueKind.Object)
                {
                    _hasMore = _sessions.Count >= PageSize;
                }
            }
            else
            {
                _sessions = new List<SessionInfo>();
                _hasMore = false;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{L["common.error"]}: {ex.Message}", Severity.Error);
            _sessions = new List<SessionInfo>();
            _hasMore = false;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task SelectSession(SessionInfo session)
    {
        _loadingDetail = true;
        _selectedDetail = null;
        StateHasChanged();

        try
        {
            using var resp = await Api.GetRawAsync($"/admin/sessions/{session.SessionId}");
            if (resp.IsSuccessStatusCode)
            {
                var detail = await resp.Content.ReadFromJsonAsync<SessionDetail>(Api.JsonOptions);
                _selectedDetail = detail ?? new SessionDetail(
                    session.SessionId, session.ChannelId, session.SenderId,
                    session.LastActive, session.Metadata, new List<SessionMessage>());
            }
            else
            {
                _selectedDetail = new SessionDetail(
                    session.SessionId, session.ChannelId, session.SenderId,
                    session.LastActive, session.Metadata, new List<SessionMessage>());
            }
        }
        catch
        {
            _selectedDetail = new SessionDetail(
                session.SessionId, session.ChannelId, session.SenderId,
                session.LastActive, session.Metadata, new List<SessionMessage>());
        }
        finally
        {
            _loadingDetail = false;
            StateHasChanged();
        }
    }

    private async Task SearchSessions()
    {
        _page = 1;
        await LoadSessions();
    }

    private async Task OnSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SearchSessions();
        }
    }

    private async Task NextPage()
    {
        _page++;
        await LoadSessions();
    }

    private async Task PrevPage()
    {
        if (_page > 1)
        {
            _page--;
            await LoadSessions();
        }
    }

    private void OpenMetadataEditor()
    {
        _metadataJson = FormatMetadata(_selectedDetail?.Metadata);
        _metadataDialog = true;
    }

    private async Task SaveMetadata()
    {
        if (_selectedDetail is null)
        {
            return;
        }

        object? body;
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(_metadataJson);
            body = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, object>>(
                doc.RootElement.GetRawText(), Api.JsonOptions);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Invalid JSON: {ex.Message}", Severity.Error);
            return;
        }

        using var resp = await Api.PostRawAsync(
            $"/admin/sessions/{_selectedDetail.SessionId}/metadata", body);

        if (resp.IsSuccessStatusCode)
        {
            Snackbar.Add(L["common.success"], Severity.Success);
            _metadataDialog = false;
            await SelectSession(new SessionInfo(
                _selectedDetail.SessionId,
                _selectedDetail.ChannelId,
                _selectedDetail.SenderId,
                _selectedDetail.LastActive,
                _selectedDetail.Metadata));
        }
        else
        {
            Snackbar.Add(L["common.error"], Severity.Error);
        }
    }

    private async Task ViewBranchDiff(string branchId)
    {
        if (_selectedDetail is null) return;
        try
        {
            using var resp = await Api.GetRawAsync(
                $"/admin/sessions/{_selectedDetail.SessionId}/diff?branchId={Uri.EscapeDataString(branchId)}");
            if (resp.IsSuccessStatusCode)
            {
                var raw = await resp.Content.ReadAsStringAsync();
                _diffContent = PrettyPrintJson(raw);
            }
            else
            {
                _diffContent = $"// HTTP {(int)resp.StatusCode}";
            }
            _diffDialog = true;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{L["common.error"]}: {ex.Message}", Severity.Error);
        }
    }

    private async Task RestoreBranch(string branchId)
    {
        var confirm = await DialogService.ShowMessageBoxAsync(
            L["sessions.restoreBranch"],
            L["sessions.confirmRestore"],
            yesText: L["common.confirm"],
            cancelText: L["common.cancel"]);
        if (confirm != true) return;

        using var resp = await Api.PostRawAsync($"/admin/branches/{branchId}/restore");
        if (resp.IsSuccessStatusCode)
        {
            Snackbar.Add(L["common.success"], Severity.Success);
        }
        else
        {
            Snackbar.Add(L["common.error"], Severity.Error);
        }
    }

    private static string FormatMetadata(Dictionary<string, object>? metadata)
    {
        if (metadata is null || metadata.Count == 0)
        {
            return "{}";
        }

        try
        {
            return System.Text.Json.JsonSerializer.Serialize(metadata,
                new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            return "{}";
        }
    }

    private static string PrettyPrintJson(string raw)
    {
        if (string.IsNullOrWhiteSpace(raw)) return string.Empty;
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(raw);
            return System.Text.Json.JsonSerializer.Serialize(doc.RootElement,
                new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        }
        catch
        {
            return raw;
        }
    }

    private static List<string> ExtractBranches(Dictionary<string, object>? metadata)
    {
        var result = new List<string>();
        if (metadata is null) return result;

        if (metadata.TryGetValue("branches", out var raw) && raw is not null)
        {
            try
            {
                if (raw is System.Text.Json.JsonElement el)
                {
                    if (el.ValueKind == System.Text.Json.JsonValueKind.Array)
                    {
                        foreach (var item in el.EnumerateArray())
                        {
                            if (item.ValueKind == System.Text.Json.JsonValueKind.String)
                            {
                                var v = item.GetString();
                                if (!string.IsNullOrEmpty(v)) result.Add(v);
                            }
                            else if (item.ValueKind == System.Text.Json.JsonValueKind.Object &&
                                     item.TryGetProperty("id", out var idEl) &&
                                     idEl.ValueKind == System.Text.Json.JsonValueKind.String)
                            {
                                var v = idEl.GetString();
                                if (!string.IsNullOrEmpty(v)) result.Add(v);
                            }
                        }
                    }
                }
            }
            catch { /* ignore */ }
        }

        return result;
    }

    private static string TruncateId(string id)
        => string.IsNullOrEmpty(id) ? "—"
            : (id.Length > 18 ? id[..8] + "…" + id[^6..] : id);

    private static string FormatTime(DateTime? dt)
        => dt?.ToLocalTime().ToString("HH:mm:ss") ?? "—";

    private static string RelativeTime(DateTime? dt)
    {
        if (dt is null) return "—";
        var diff = DateTime.UtcNow - dt.Value.ToUniversalTime();
        if (diff.TotalSeconds < 60) return $"{(int)diff.TotalSeconds}s";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h";
        if (diff.TotalDays < 30) return $"{(int)diff.TotalDays}d";
        return dt.Value.ToLocalTime().ToString("yyyy-MM-dd");
    }

    public void Dispose()
    {
        L.OnLanguageChanged -= HandleLanguageChanged;
    }
}
