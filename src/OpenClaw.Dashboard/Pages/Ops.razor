@page "/ops"
@implements IDisposable
@inject ApiService Api
@inject LocalizationService L
@inject AuthService Auth
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>@L["ops.title"] · OpenClaw</PageTitle>

@if (!Auth.HasRole("operator"))
{
    <MudPaper Class="pa-8 d-flex flex-column align-center" Elevation="0">
        <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large" Color="Color.Warning" />
        <MudText Typo="Typo.h6" Class="mt-4">@L["auth.notAuthenticated"]</MudText>
    </MudPaper>
}
else
{
    <div class="ops-shell">
        <header class="ops-header">
            <div>
                <div class="ops-eyebrow">// CONTROL PLANE</div>
                <MudText Typo="Typo.h4" Class="ops-title">@L["ops.title"]</MudText>
            </div>
            <MudTooltip Text="@L["common.refresh"]">
                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                               Color="Color.Primary"
                               Disabled="_loading"
                               OnClick="LoadData" />
            </MudTooltip>
        </header>

        <MudTabs Elevation="0"
                 Rounded="true"
                 ApplyEffectsToContainer="true"
                 Class="ops-tabs">

            <MudTabPanel Icon="@Icons.Material.Filled.Extension" Text="@L["ops.plugins"]" Class="pa-0 pt-6">
                @if (_loading && _plugins is null)
                {
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="320px" />
                }
                else if (_plugins is null || _plugins.Count == 0)
                {
                    <EmptyHint Icon="@Icons.Material.Filled.ExtensionOff"
                               Title="@L["common.noData"]"
                               Subtitle="@L["ops.plugins"]" />
                }
                else
                {
                    <MudDataGrid T="PluginInfo"
                                 Items="_plugins"
                                 Dense="true"
                                 Hover="true"
                                 Bordered="false"
                                 Striped="false"
                                 Elevation="0"
                                 Class="ops-grid">
                        <Columns>
                            <PropertyColumn Property="x => x.Name" Title="@L["ops.pluginName"]">
                                <CellTemplate>
                                    <div class="d-flex align-center gap-2">
                                        <span class="ops-dot" style="background:@PluginAccent(context.Item)"></span>
                                        <MudText Typo="Typo.body2" Class="font-weight-bold">
                                            @(string.IsNullOrEmpty(context.Item.Name) ? context.Item.Id : context.Item.Name)
                                        </MudText>
                                    </div>
                                </CellTemplate>
                            </PropertyColumn>
                            <PropertyColumn Property="x => x.Description" Title="@L["common.description"]">
                                <CellTemplate>
                                    <MudText Typo="Typo.body2" Style="opacity:.78">
                                        @(context.Item.Description ?? "—")
                                    </MudText>
                                </CellTemplate>
                            </PropertyColumn>
                            <PropertyColumn Property="x => x.Version" Title="v">
                                <CellTemplate>
                                    <span class="ops-version-pill">@(context.Item.Version ?? "—")</span>
                                </CellTemplate>
                            </PropertyColumn>
                            <PropertyColumn Property="x => x.Enabled" Title="@L["common.status"]">
                                <CellTemplate>
                                    <MudChip T="string"
                                             Size="Size.Small"
                                             Color="@(context.Item.Enabled ? Color.Success : Color.Default)"
                                             Variant="@(context.Item.Enabled ? Variant.Filled : Variant.Outlined)">
                                        @(context.Item.Enabled ? L["common.enabled"] : L["common.disabled"])
                                    </MudChip>
                                </CellTemplate>
                            </PropertyColumn>
                            <TemplateColumn Title="@L["common.actions"]" Sortable="false" Filterable="false">
                                <CellTemplate>
                                    <MudButton Size="Size.Small"
                                               Variant="Variant.Outlined"
                                               Color="@(context.Item.Enabled ? Color.Warning : Color.Success)"
                                               StartIcon="@(context.Item.Enabled ? Icons.Material.Filled.PauseCircle : Icons.Material.Filled.PlayCircle)"
                                               OnClick="@(() => TogglePlugin(context.Item))">
                                        @(context.Item.Enabled ? L["common.disable"] : L["common.enable"])
                                    </MudButton>
                                </CellTemplate>
                            </TemplateColumn>
                        </Columns>
                    </MudDataGrid>
                }
            </MudTabPanel>

            <MudTabPanel Icon="@Icons.Material.Filled.Gavel" Text="@L["ops.approvalPolicies"]" Class="pa-0 pt-6">
                @if (_loading && _policies is null)
                {
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="280px" />
                }
                else if (_policies is null || _policies.Count == 0)
                {
                    <EmptyHint Icon="@Icons.Material.Filled.RuleFolder"
                               Title="@L["common.noData"]"
                               Subtitle="@L["ops.approvalPolicies"]" />
                }
                else
                {
                    <MudSimpleTable Hover="true" Dense="true" Bordered="false" Striped="false" Class="ops-simple-table">
                        <thead>
                            <tr>
                                <th>@L["ops.toolPattern"]</th>
                                <th>@L["ops.policy"]</th>
                                <th>@L["common.description"]</th>
                                <th style="width:120px;text-align:right">@L["common.actions"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in _policies)
                            {
                                <tr>
                                    <td><code class="ops-mono">@(p.ToolPattern ?? "*")</code></td>
                                    <td>
                                        <MudChip T="string"
                                                 Size="Size.Small"
                                                 Variant="Variant.Outlined"
                                                 Color="@PolicyColor(p.Policy)">
                                            @(p.Policy ?? "—")
                                        </MudChip>
                                    </td>
                                    <td>
                                        <MudText Typo="Typo.body2" Style="opacity:.78">
                                            @(p.Description ?? "—")
                                        </MudText>
                                    </td>
                                    <td style="text-align:right">
                                        <MudIconButton Size="Size.Small"
                                                       Icon="@Icons.Material.Filled.DeleteOutline"
                                                       Color="Color.Error"
                                                       OnClick="@(() => DeletePolicy(p.Id))" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                }
            </MudTabPanel>

            <MudTabPanel Icon="@Icons.Material.Filled.ReportGmailerrorred" Text="@L["ops.deadLetterQueue"]" Class="pa-0 pt-6">
                @if (_loading && _deadLetters is null)
                {
                    <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="280px" />
                }
                else if (_deadLetters is null || _deadLetters.Count == 0)
                {
                    <EmptyHint Icon="@Icons.Material.Filled.MarkEmailRead"
                               Title="@L["common.noData"]"
                               Subtitle="@L["ops.deadLetterQueue"]" />
                }
                else
                {
                    <MudDataGrid T="DeadLetterItem"
                                 Items="_deadLetters"
                                 Dense="true"
                                 Hover="true"
                                 Elevation="0"
                                 Bordered="false"
                                 Class="ops-grid">
                        <Columns>
                            <PropertyColumn Property="x => x.WebhookUrl" Title="@L["ops.webhookUrl"]">
                                <CellTemplate>
                                    <code class="ops-mono ops-mono-truncate"
                                          title="@context.Item.WebhookUrl">
                                        @(context.Item.WebhookUrl ?? "—")
                                    </code>
                                </CellTemplate>
                            </PropertyColumn>
                            <PropertyColumn Property="x => x.Error" Title="@L["ops.errorMessage"]">
                                <CellTemplate>
                                    <MudText Typo="Typo.caption" Color="Color.Error">
                                        @(context.Item.Error ?? "—")
                                    </MudText>
                                </CellTemplate>
                            </PropertyColumn>
                            <PropertyColumn Property="x => x.FailedAt" Title="@L["ops.failedAt"]">
                                <CellTemplate>
                                    <MudText Typo="Typo.caption" Style="opacity:.78">
                                        @FormatDate(context.Item.FailedAt)
                                    </MudText>
                                </CellTemplate>
                            </PropertyColumn>
                            <PropertyColumn Property="x => x.RetryCount" Title="@L["ops.retryCount"]">
                                <CellTemplate>
                                    <span class="ops-retry-pill">×@context.Item.RetryCount</span>
                                </CellTemplate>
                            </PropertyColumn>
                            <TemplateColumn Title="@L["common.actions"]" Sortable="false" Filterable="false">
                                <CellTemplate>
                                    <div class="d-flex gap-1">
                                        <MudIconButton Size="Size.Small"
                                                       Icon="@Icons.Material.Filled.Refresh"
                                                       Color="Color.Primary"
                                                       OnClick="@(() => RetryDeadLetter(context.Item.Id))"
                                                       title="@L["common.retry"]" />
                                        <MudIconButton Size="Size.Small"
                                                       Icon="@Icons.Material.Filled.DeleteSweep"
                                                       Color="Color.Error"
                                                       OnClick="@(() => DiscardDeadLetter(context.Item.Id))"
                                                       title="@L["common.discard"]" />
                                    </div>
                                </CellTemplate>
                            </TemplateColumn>
                        </Columns>
                    </MudDataGrid>
                }
            </MudTabPanel>
        </MudTabs>
    </div>
}

<style>
    .ops-shell { max-width: 1320px; margin: 0 auto; }
    .ops-header {
        display:flex; align-items:flex-end; justify-content:space-between;
        padding: 8px 4px 24px; border-bottom: 1px solid var(--mud-palette-lines-default);
        margin-bottom: 16px;
    }
    .ops-eyebrow {
        font-family: 'JetBrains Mono', 'Consolas', monospace;
        font-size: 11px; letter-spacing: .18em; color: var(--mud-palette-tertiary);
        margin-bottom: 6px; opacity:.75;
    }
    .ops-title { font-weight: 700; letter-spacing: -.02em; }
    .ops-tabs ::deep .mud-tab { text-transform: none; letter-spacing: 0; font-weight: 500; }

    .ops-grid ::deep .mud-table-cell { border-bottom-color: var(--mud-palette-lines-default); }
    .ops-grid ::deep .mud-table-head .mud-table-cell {
        text-transform: uppercase; font-size: 11px; letter-spacing: .12em;
        color: var(--mud-palette-text-secondary); font-weight:600;
    }
    .ops-simple-table { background: transparent; }
    .ops-simple-table ::deep th {
        text-transform: uppercase; font-size: 11px; letter-spacing: .12em;
        color: var(--mud-palette-text-secondary);
    }
    .ops-mono {
        font-family: 'JetBrains Mono','Consolas',monospace;
        font-size: 12px; padding: 2px 6px; border-radius: 4px;
        background: rgba(139,92,246,.08); color: var(--mud-palette-primary);
    }
    .ops-mono-truncate { display:inline-block; max-width: 280px;
        overflow:hidden; text-overflow:ellipsis; white-space:nowrap; vertical-align:middle; }
    .ops-version-pill {
        font-family: 'JetBrains Mono','Consolas',monospace; font-size: 11px;
        padding: 2px 8px; border-radius: 999px;
        border: 1px solid var(--mud-palette-lines-default);
        color: var(--mud-palette-text-secondary);
    }
    .ops-retry-pill {
        font-family: 'JetBrains Mono','Consolas',monospace; font-size: 12px;
        padding: 2px 10px; border-radius: 999px; font-weight: 600;
        background: linear-gradient(135deg, rgba(245,158,11,.15), rgba(239,68,68,.15));
        color: var(--mud-palette-warning);
    }
    .ops-dot {
        width: 8px; height: 8px; border-radius: 50%;
        box-shadow: 0 0 0 3px rgba(255,255,255,.04);
    }
</style>

@code {
    private List<PluginInfo>? _plugins;
    private List<ApprovalPolicy>? _policies;
    private List<DeadLetterItem>? _deadLetters;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        L.OnLanguageChanged += HandleLanguageChanged;
        await LoadData();
    }

    private void HandleLanguageChanged() => InvokeAsync(StateHasChanged);

    private async Task LoadData()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            var pluginsTask = Api.GetRawAsync("/admin/plugins");
            var policiesTask = Api.GetRawAsync("/tools/approval-policies");
            var deadLettersTask = Api.GetRawAsync("/admin/webhooks/dead-letter");
            await Task.WhenAll(pluginsTask, policiesTask, deadLettersTask);

            _plugins = await ParseListAsync<PluginInfo>(pluginsTask.Result, "plugins");
            _policies = await ParseListAsync<ApprovalPolicy>(policiesTask.Result, "policies");
            _deadLetters = await ParseListAsync<DeadLetterItem>(deadLettersTask.Result, "items");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{L["common.error"]}: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task<List<T>?> ParseListAsync<T>(HttpResponseMessage response, params string[] arrayKeys)
    {
        using (response)
        {
            if (!response.IsSuccessStatusCode)
            {
                return null;
            }

            try
            {
                using var stream = await response.Content.ReadAsStreamAsync();
                using var doc = await System.Text.Json.JsonDocument.ParseAsync(stream);
                var root = doc.RootElement;

                System.Text.Json.JsonElement target = root;
                if (root.ValueKind == System.Text.Json.JsonValueKind.Object)
                {
                    foreach (var key in arrayKeys)
                    {
                        if (root.TryGetProperty(key, out var arr) &&
                            arr.ValueKind == System.Text.Json.JsonValueKind.Array)
                        {
                            target = arr;
                            break;
                        }
                    }
                }

                if (target.ValueKind != System.Text.Json.JsonValueKind.Array)
                {
                    return new List<T>();
                }

                var raw = target.GetRawText();
                return System.Text.Json.JsonSerializer.Deserialize<List<T>>(raw, Api.JsonOptions)
                       ?? new List<T>();
            }
            catch
            {
                return new List<T>();
            }
        }
    }

    private async Task TogglePlugin(PluginInfo plugin)
    {
        var action = plugin.Enabled ? "disable" : "enable";
        using var resp = await Api.PostRawAsync($"/admin/plugins/{plugin.Id}/{action}");
        if (resp.IsSuccessStatusCode)
        {
            Snackbar.Add(L["common.success"], Severity.Success);
            await LoadData();
        }
        else
        {
            Snackbar.Add(L["common.error"], Severity.Error);
        }
    }

    private async Task DeletePolicy(string? id)
    {
        if (string.IsNullOrEmpty(id))
        {
            return;
        }

        var confirm = await DialogService.ShowMessageBoxAsync(
            L["ops.approvalPolicies"],
            L["ops.confirmDeletePolicy"],
            yesText: L["common.delete"],
            cancelText: L["common.cancel"]);
        if (confirm != true)
        {
            return;
        }

        using var resp = await Api.DeleteAsync($"/tools/approval-policies/{id}");
        if (resp.IsSuccessStatusCode)
        {
            Snackbar.Add(L["common.success"], Severity.Success);
            await LoadData();
        }
        else
        {
            Snackbar.Add(L["common.error"], Severity.Error);
        }
    }

    private async Task RetryDeadLetter(string? id)
    {
        if (string.IsNullOrEmpty(id)) return;
        using var resp = await Api.PostRawAsync($"/admin/webhooks/dead-letter/{id}/retry");
        if (resp.IsSuccessStatusCode)
        {
            Snackbar.Add(L["common.success"], Severity.Success);
            await LoadData();
        }
        else
        {
            Snackbar.Add(L["common.error"], Severity.Error);
        }
    }

    private async Task DiscardDeadLetter(string? id)
    {
        if (string.IsNullOrEmpty(id)) return;
        var confirm = await DialogService.ShowMessageBoxAsync(
            L["ops.deadLetterQueue"],
            L["common.discard"] + "?",
            yesText: L["common.discard"],
            cancelText: L["common.cancel"]);
        if (confirm != true) return;

        using var resp = await Api.PostRawAsync($"/admin/webhooks/dead-letter/{id}/discard");
        if (resp.IsSuccessStatusCode)
        {
            Snackbar.Add(L["common.success"], Severity.Success);
            await LoadData();
        }
        else
        {
            Snackbar.Add(L["common.error"], Severity.Error);
        }
    }

    private static string PluginAccent(PluginInfo p)
        => p.Enabled ? "#10b981" : "#475569";

    private static Color PolicyColor(string? policy)
        => policy?.ToLowerInvariant() switch
        {
            "allow" => Color.Success,
            "deny" or "block" => Color.Error,
            "require_approval" or "approval" => Color.Warning,
            _ => Color.Default
        };

    private static string FormatDate(DateTime? dt)
        => dt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss") ?? "—";

    public void Dispose()
    {
        L.OnLanguageChanged -= HandleLanguageChanged;
    }
}
