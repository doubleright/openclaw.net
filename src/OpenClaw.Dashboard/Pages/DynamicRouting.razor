@code {
    private JsonElement? _providerState;
    private string? _defaultProfileId;
    private List<JsonElement> _profiles = new();
    private List<JsonElement> _routes = new();
    private List<JsonElement> _policies = new();
    private bool _loading = true;
    private bool _hasLoaded;
    private string? _error;

    private string _policyId = string.Empty;
    private int _policyPriority;
    private string _policyProviderId = string.Empty;
    private string _policyModelId = string.Empty;
    private string _policyFallbackModels = string.Empty;
    private string _policyChannelId = string.Empty;
    private string _policySenderId = string.Empty;
    private string _policySessionId = string.Empty;
    private int _policyMaxInputTokens;
    private int _policyMaxOutputTokens;
    private int _policyMaxTotalTokens;
    private bool _policyEnabled;
    private bool _policySaving;
    private string? _editingPolicyId;

    private int _profileCount;
    private int _routeCount;
    private int _dynamicRouteCount;
    private int _policyCount;

    protected override async Task OnInitializedAsync()
    {
        L.OnLanguageChanged += HandleLanguageChanged;
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            _providerState = await TryGetJsonAsync("admin/providers").ConfigureAwait(false);
            _defaultProfileId = ReadString(_providerState, "modelProfiles", "defaultProfileId");
            _profiles = ReadObjectArray(_providerState, "modelProfiles", "profiles");
            _routes = ReadObjectArray(_providerState, "routes");
            _policies = ReadObjectArray(_providerState, "policies");

            _profileCount = _profiles.Count;
            _routeCount = _routes.Count;
            _dynamicRouteCount = _routes.Count(route => ReadBool(route, "isDynamic"));
            _policyCount = _policies.Count;
            EnsurePolicyDraftDefaults();
            _hasLoaded = true;
        }
        catch (Exception ex) when (IsExpectedDashboardOperationException(ex))
        {
            Logger.LogWarning(ex, "Failed to load Dynamic Routing dashboard data.");
            _error = L["common.error"];
            Snackbar.Add(L["common.error"], Severity.Error);
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void ResetPolicyDraft()
    {
        _editingPolicyId = null;
        _policyId = string.Empty;
        _policyPriority = 0;
        _policyFallbackModels = string.Empty;
        _policyChannelId = string.Empty;
        _policySenderId = string.Empty;
        _policySessionId = string.Empty;
        _policyMaxInputTokens = 0;
        _policyMaxOutputTokens = 0;
        _policyMaxTotalTokens = 0;
        _policyEnabled = false;

        var profile = GetDefaultProfile();
        if (profile is not null)
        {
            _policyProviderId = ReadString(profile, "providerId") ?? string.Empty;
            _policyModelId = ReadString(profile, "modelId") ?? string.Empty;
            _policyFallbackModels = string.Join(", ", ReadStringArray(profile, "fallbackProfileIds"));
        }
        else
        {
            _policyProviderId = string.Empty;
            _policyModelId = string.Empty;
        }
    }

    private void EnsurePolicyDraftDefaults()
    {
        if (!string.IsNullOrWhiteSpace(_policyProviderId) && !string.IsNullOrWhiteSpace(_policyModelId))
        {
            return;
        }

        ResetPolicyDraft();
    }

    private JsonElement? GetDefaultProfile()
    {
        if (!string.IsNullOrWhiteSpace(_defaultProfileId))
        {
            var matched = _profiles.FirstOrDefault(profile => string.Equals(ReadString(profile, "id"), _defaultProfileId, StringComparison.OrdinalIgnoreCase));
            if (matched.ValueKind != JsonValueKind.Undefined)
            {
                return matched;
            }
        }

        var firstProfile = _profiles.FirstOrDefault();
        return firstProfile.ValueKind == JsonValueKind.Undefined ? null : firstProfile;
    }

    private object BuildPolicyPayload(bool? enabledOverride = null)
        => new
        {
            id = string.IsNullOrWhiteSpace(_policyId) ? null : _policyId.Trim(),
            priority = _policyPriority,
            enabled = enabledOverride ?? _policyEnabled,
            providerId = _policyProviderId.Trim(),
            modelId = _policyModelId.Trim(),
            fallbackModels = ParseFallbackModels(_policyFallbackModels),
            channelId = NormalizeOptional(_policyChannelId),
            senderId = NormalizeOptional(_policySenderId),
            sessionId = NormalizeOptional(_policySessionId),
            maxInputTokens = _policyMaxInputTokens,
            maxOutputTokens = _policyMaxOutputTokens,
            maxTotalTokens = _policyMaxTotalTokens
        };

    private object BuildPolicyPayload(JsonElement policy, bool? enabledOverride = null)
        => new
        {
            id = ReadString(policy, "id"),
            priority = ReadLong(policy, "priority"),
            enabled = enabledOverride ?? ReadBool(policy, "enabled"),
            providerId = ReadString(policy, "providerId") ?? string.Empty,
            modelId = ReadString(policy, "modelId") ?? string.Empty,
            fallbackModels = ReadStringArray(policy, "fallbackModels").ToArray(),
            channelId = ReadString(policy, "channelId"),
            senderId = ReadString(policy, "senderId"),
            sessionId = ReadString(policy, "sessionId"),
            maxInputTokens = ReadLong(policy, "maxInputTokens"),
            maxOutputTokens = ReadLong(policy, "maxOutputTokens"),
            maxTotalTokens = ReadLong(policy, "maxTotalTokens")
        };

    private static string[] ParseFallbackModels(string? value)
        => string.IsNullOrWhiteSpace(value)
            ? []
            : value.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Where(item => !string.IsNullOrWhiteSpace(item))
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToArray();

    private static string? NormalizeOptional(string? value)
    {
        var trimmed = value?.Trim();
        return string.IsNullOrWhiteSpace(trimmed) ? null : trimmed;
    }

    private async Task CreatePolicyAsync()
    {
        if (string.IsNullOrWhiteSpace(_policyProviderId) || string.IsNullOrWhiteSpace(_policyModelId))
        {
            Snackbar.Add(L["common.error"], Severity.Error);
            return;
        }

        _policySaving = true;
        try
        {
            using var response = await Api.PostRawAsync("/admin/providers/policies", BuildPolicyPayload());
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add(L["common.success"], Severity.Success);
                ResetPolicyDraft();
                await LoadData();
            }
            else
            {
                Snackbar.Add(await ReadResponseMessageAsync(response), Severity.Error);
            }
        }
        catch (Exception ex) when (IsExpectedDashboardOperationException(ex))
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _policySaving = false;
        }
    }

    private void EditPolicy(JsonElement policy)
    {
        _editingPolicyId = ReadString(policy, "id");
        _policyId = _editingPolicyId ?? string.Empty;
        _policyPriority = (int)ReadLong(policy, "priority");
        _policyProviderId = ReadString(policy, "providerId") ?? string.Empty;
        _policyModelId = ReadString(policy, "modelId") ?? string.Empty;
        _policyFallbackModels = string.Join(", ", ReadStringArray(policy, "fallbackModels"));
        _policyChannelId = ReadString(policy, "channelId") ?? string.Empty;
        _policySenderId = ReadString(policy, "senderId") ?? string.Empty;
        _policySessionId = ReadString(policy, "sessionId") ?? string.Empty;
        _policyMaxInputTokens = (int)ReadLong(policy, "maxInputTokens");
        _policyMaxOutputTokens = (int)ReadLong(policy, "maxOutputTokens");
        _policyMaxTotalTokens = (int)ReadLong(policy, "maxTotalTokens");
        _policyEnabled = ReadBool(policy, "enabled");
    }

    private async Task TogglePolicyEnabledAsync(JsonElement policy)
    {
        var policyId = ReadString(policy, "id");
        if (string.IsNullOrWhiteSpace(policyId))
        {
            Snackbar.Add(L["common.error"], Severity.Error);
            return;
        }

        using var response = await Api.PostRawAsync("/admin/providers/policies", BuildPolicyPayload(policy, enabledOverride: !ReadBool(policy, "enabled")));
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add(L["common.success"], Severity.Success);
            await LoadData();
        }
        else
        {
            Snackbar.Add(await ReadResponseMessageAsync(response), Severity.Error);
        }
    }

    private async Task DeletePolicyAsync(JsonElement policy)
    {
        var policyId = ReadString(policy, "id");
        if (string.IsNullOrWhiteSpace(policyId))
        {
            Snackbar.Add(L["common.error"], Severity.Error);
            return;
        }

        var confirm = await DialogService.ShowMessageBoxAsync(
            L["routing.policyRules"],
            L["routing.confirmDeleteProviderPolicy"],
            yesText: L["common.delete"],
            cancelText: L["common.cancel"]);
        if (confirm != true)
        {
            return;
        }

        using var response = await Api.DeleteAsync($"/admin/providers/policies/{Uri.EscapeDataString(policyId)}");
        if (response.IsSuccessStatusCode)
        {
            Snackbar.Add(L["common.success"], Severity.Success);
            await LoadData();
        }
        else
        {
            Snackbar.Add(await ReadResponseMessageAsync(response), Severity.Error);
        }
    }

    private static async Task<string> ReadResponseMessageAsync(HttpResponseMessage response)
    {
        try
        {
            var content = await response.Content.ReadAsStringAsync().ConfigureAwait(false);
            return string.IsNullOrWhiteSpace(content) ? $"Request failed ({(int)response.StatusCode})" : content;
        }
        catch (Exception ex) when (IsExpectedDashboardOperationException(ex))
        {
            return $"Request failed ({(int)response.StatusCode})";
        }
    }

    private async Task<JsonElement?> TryGetJsonAsync(string url)
    {
        using var response = await Api.GetRawAsync(url).ConfigureAwait(false);
        if (!response.IsSuccessStatusCode)
        {
            return null;
        }

        await using var stream = await response.Content.ReadAsStreamAsync().ConfigureAwait(false);
        using var document = await JsonDocument.ParseAsync(stream).ConfigureAwait(false);
        return document.RootElement.Clone();
    }

    private static bool IsExpectedDashboardOperationException(Exception ex)
        => ex is HttpRequestException
            or IOException
            or InvalidOperationException
            or JsonException
            or NotSupportedException
            or ObjectDisposedException
            or TaskCanceledException;

    private static List<JsonElement> ReadObjectArray(JsonElement? root, params string[] path)
    {
        var element = TryGetProperty(root, path);
        if (element is null || element.Value.ValueKind != JsonValueKind.Array)
        {
            return new List<JsonElement>();
        }

        return element.Value.EnumerateArray().Select(item => item.Clone()).ToList();
    }

    private static JsonElement? TryGetProperty(JsonElement? root, params string[] path)
    {
        if (root is null)
        {
            return null;
        }

        var current = root.Value;
        foreach (var segment in path)
        {
            if (current.ValueKind != JsonValueKind.Object || !current.TryGetProperty(segment, out var next))
            {
                return null;
            }

            current = next;
        }

        return current;
    }

    private static string? ReadString(JsonElement? root, params string[] path)
    {
        var element = TryGetProperty(root, path);
        if (element is null)
        {
            return null;
        }

        return element.Value.ValueKind switch
        {
            JsonValueKind.String => element.Value.GetString(),
            JsonValueKind.Null => null,
            _ => element.Value.ToString()
        };
    }

    private static bool ReadBool(JsonElement? root, params string[] path)
    {
        var element = TryGetProperty(root, path);
        if (element is null)
        {
            return false;
        }

        if (element.Value.ValueKind == JsonValueKind.True || element.Value.ValueKind == JsonValueKind.False)
        {
            return element.Value.GetBoolean();
        }

        return bool.TryParse(element.Value.ToString(), out var result) && result;
    }

    private static long ReadLong(JsonElement? root, params string[] path)
    {
        var element = TryGetProperty(root, path);
        if (element is null)
        {
            return 0;
        }

        if (element.Value.ValueKind == JsonValueKind.Number && element.Value.TryGetInt64(out var number))
        {
            return number;
        }

        return long.TryParse(element.Value.ToString(), out var parsed) ? parsed : 0;
    }

    private static List<string> ReadStringArray(JsonElement? root, params string[] path)
    {
        var element = TryGetProperty(root, path);
        if (element is null || element.Value.ValueKind != JsonValueKind.Array)
        {
            return new List<string>();
        }

        return element.Value.EnumerateArray()
            .Select(item => item.ValueKind == JsonValueKind.String ? item.GetString() : item.ToString())
            .Where(item => !string.IsNullOrWhiteSpace(item))
            .ToList()!;
    }

    private static List<string> BuildCapabilityLabels(JsonElement profile)
    {
        var capabilities = TryGetProperty(profile, "capabilities");
        if (capabilities is null)
        {
            return [];
        }

        var labels = new List<string>();

        if (ReadBool(capabilities, "supportsTools")) labels.Add("tools");
        if (ReadBool(capabilities, "supportsVision")) labels.Add("vision");
        if (ReadBool(capabilities, "supportsStructuredOutputs")) labels.Add("structured");
        if (ReadBool(capabilities, "supportsJsonSchema")) labels.Add("json-schema");
        if (ReadBool(capabilities, "supportsStreaming")) labels.Add("streaming");
        if (ReadBool(capabilities, "supportsReasoningEffort")) labels.Add("reasoning");

        return labels;
    }

    private static Color CircuitColor(string? circuitState)
        => circuitState?.ToLowerInvariant() switch
        {
            "closed" => Color.Success,
            "halfopen" => Color.Warning,
            "half-open" => Color.Warning,
            "open" => Color.Error,
            _ => Color.Default
        };

    private void HandleLanguageChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        L.OnLanguageChanged -= HandleLanguageChanged;
    }
}
